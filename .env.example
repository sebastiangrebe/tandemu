# ENCRYPTION_KEY=

# OAuth (optional — providers auto-enabled when credentials are set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Sentry (SaaS only — leave empty for OSS)
# SENTRY_BACKEND_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT_FRONTEND=

